{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Remote Data Blocks local playground",
    "description": "Runs Remote Data Blocks plugin in a local WordPress Playground",
    "author": "WordPress VIP",
    "categories": [ "Content" ]
  },
  "features": {
    "networking": true
  },
  "landingPage": "/wp-admin/post.php?post=4&action=edit",
  "login": true,
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Remote Data Blocks",
        "blogdescription": "Explore the Remote Data Blocks plugin in a WordPress Playground"
      }
    },
    {
      "step": "activatePlugin",
      "pluginPath": "remote-data-blocks/remote-data-blocks.php"
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/Automattic/remote-data-blocks/refs/heads/trunk/example/assets/blueprint-content.wxr"
      }
    }
  ]
}
